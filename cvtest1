function applyHealthBonus(char, bonus, multiplier)
	local hum = getHumanoid(char)
	if not hum then
		return
	end

	local base = rememberBaseHealth(hum)
	multiplier = multiplier or 1
	local oldMax = hum.MaxHealth
	local oldHealth = hum.Health
	local newMax = (base + bonus) * multiplier

	hum.MaxHealth = newMax
	if oldHealth > 0 then
		local gainedMax = math.max(newMax - oldMax, 0)
		hum.Health = math.min(newMax, oldHealth + gainedMax)
	end
end

