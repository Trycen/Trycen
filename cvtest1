function getNearestHumanoidAtPosition(ownerPlr, hitPos, range, includeSelf)
	if typeof(hitPos) ~= "Vector3" then
		return nil, nil
	end

	local ownerChar = getCharacter(ownerPlr)
	local ownerRoot = getRoot(ownerChar)
	if not ownerRoot then
		return nil, nil
	end

	local params = OverlapParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = {}

	local parts = Workspace:GetPartBoundsInRadius(hitPos, 8, params)
	local bestHum = nil
	local bestRoot = nil
	local bestDistance = math.huge

	for _, part in ipairs(parts) do
		local model = part:FindFirstAncestorOfClass("Model")
		if model and (includeSelf or model ~= ownerChar) then
			local hum = getHumanoid(model)
			local root = getRoot(model)
			if hum and hum.Health > 0 and root then
				local casterDistance = (ownerRoot.Position - root.Position).Magnitude
				if casterDistance <= range then
					local clickDistance = (hitPos - root.Position).Magnitude
					if clickDistance < bestDistance then
						bestDistance = clickDistance
						bestHum = hum
						bestRoot = root
					end
				end
			end
		end
	end

	return bestHum, bestRoot
end

function findTargetHumanoid(ownerPlr, hit, hitPos, range, includeSelf)
	local ownerChar = getCharacter(ownerPlr)
	local ownerRoot = getRoot(ownerChar)
	if not ownerRoot then
		return nil, nil
	end

	if typeof(hit) == "Instance" then
		local model = hit:FindFirstAncestorOfClass("Model")
		if model and (includeSelf or model ~= ownerChar) then
			local hum = getHumanoid(model)
			local root = getRoot(model)
			if hum and hum.Health > 0 and root and (ownerRoot.Position - root.Position).Magnitude <= range then
				return hum, root
			end
		end
	end

	local hum, root = getNearestHumanoidAtPosition(ownerPlr, hitPos, range, includeSelf)
	if hum then
		return hum, root
	end

	if includeSelf then
		local selfHum = getHumanoid(ownerChar)
		if selfHum and selfHum.Health > 0 then
			return selfHum, ownerRoot
		end
	end

	return nil, nil
end

function teleportPlayer(plr, targetPos)
	if not hasPower(plr, "Teleportation") or not hasEquippedTool(plr, TELEPORT_TOOL_NAME) then
		return
	end

	if typeof(targetPos) ~= "Vector3" then
		return
	end

	local now = os.clock()
	if (teleportCooldownUntil[plr] or 0) > now then
		sendCooldown(plr, "Teleport", teleportCooldownUntil[plr])
		return
	end

	local char = getCharacter(plr)
	local root = getRoot(char)
	local hum = getHumanoid(char)
	if not root or not hum or hum.Health <= 0 then
		return
	end

	local offset = targetPos - root.Position
	if offset.Magnitude > TELEPORT_RANGE then
		targetPos = root.Position + offset.Unit * TELEPORT_RANGE
	end

	local oldPos = root.Position
	local finalPos = targetPos + Vector3.new(0, 3, 0)
	makeSparkleBurst(oldPos, Color3.fromRGB(35, 190, 255), 26, 0.7)
	root.CFrame = CFrame.new(finalPos, finalPos + root.CFrame.LookVector)
	root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
	makeSparkleBurst(finalPos, Color3.fromRGB(35, 190, 255), 42, 1)

	local params = OverlapParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = { char }

	local parts = Workspace:GetPartBoundsInRadius(finalPos, TELEPORT_AOE_RADIUS, params)
	local seen = {}
	for _, part in ipairs(parts) do
		local model = part:FindFirstAncestorOfClass("Model")
		if model and model ~= char and not seen[model] then
			seen[model] = true
			local targetHum = getHumanoid(model)
			if targetHum and targetHum.Health > 0 then
				targetHum:TakeDamage(TELEPORT_AOE_DAMAGE * getDamageMultiplier(plr))
			end
		end
	end

	local duration = getCooldownDuration(plr, TELEPORT_COOLDOWN)
	teleportCooldownUntil[plr] = now + duration
	sendCooldownStarted(plr, "Teleport", duration)
end

function healTarget(plr, percent, hit, hitPos)
	if not hasPower(plr, "Healing") then
		return
	end

	local toolName = percent >= 0.25 and HEAL_25_TOOL_NAME or HEAL_5_TOOL_NAME
	if not hasEquippedTool(plr, toolName) then
		return
	end

	local now = os.clock()
	local key = percent >= 0.25 and "Big" or "Small"
	local cooldown = percent >= 0.25 and HEAL_25_COOLDOWN or HEAL_5_COOLDOWN

	if not healCooldownUntil[plr] then
		healCooldownUntil[plr] = {}
	end

	if (healCooldownUntil[plr][key] or 0) > now then
		sendCooldown(plr, "Heal", healCooldownUntil[plr][key])
		return
	end

	local hum = findTargetHumanoid(plr, hit, hitPos, HEAL_RANGE, true)
	if not hum then
		return
	end

	hum.Health = math.min(hum.MaxHealth, hum.Health + hum.MaxHealth * percent)
	cooldown = getCooldownDuration(plr, cooldown)
	healCooldownUntil[plr][key] = now + cooldown
	local healRoot = getRoot(hum.Parent)
	if healRoot then
		makeSparkleBurst(healRoot.Position, Color3.fromRGB(80, 255, 160), 22, 0.65)
	end
	sendCooldownStarted(plr, "Heal", cooldown)
end

function startWeepingRegeneration(plr)
	if not hasPower(plr, "Healing") or not hasEquippedTool(plr, WEEPING_REGEN_TOOL_NAME) then
		return
	end

	local now = os.clock()
