function applyPassiveRegen(plr, dt)
	local char = getCharacter(plr)
	local hum = getHumanoid(char)
	if not hum or hum.Health <= 0 then
		return
	end

	local regenRate = getPassiveRegenRate(plr)
	if regenRate <= 0 then
		return
	end

	if hum.Health >= hum.MaxHealth then
		return
	end

	hum.Health = math.min(hum.MaxHealth, hum.Health + hum.MaxHealth * regenRate * dt)
end

function collectElectricTargets(char, centerPos, radius)
	local params = OverlapParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = { char }
	params.RespectCanCollide = false
	params.MaxParts = 0

	local parts = Workspace:GetPartBoundsInRadius(centerPos, radius, params)
	local seen = {}
	local targets = {}

	for _, part in ipairs(parts) do
		local model = part:FindFirstAncestorOfClass("Model")
		if model and model ~= char and not seen[model] then
			seen[model] = true
			local thum = getHumanoid(model)
			local troot = getRoot(model)
			if thum and thum.Health > 0 and troot then
				table.insert(targets, {
					hum = thum,
					root = troot,
					dist = (troot.Position - centerPos).Magnitude,
				})
			end
		end
	end

	table.sort(targets, function(a, b)
		return a.dist < b.dist
	end)

	return targets
end

function useElectricity(plr, action, hit, hitPos)
	if not hasPower(plr, "Electricity") then
		return
	end

	local toolMap = {
		Strike = ELEC_STRIKE_TOOL_NAME,
		Stun = ELEC_STUN_TOOL_NAME,
		Discharge = ELEC_DISCHARGE_TOOL_NAME,
		Thunderstorm = ELEC_ULT_TOOL_NAME,
	}

	local requiredTool = toolMap[action]
	if not requiredTool or not hasEquippedTool(plr, requiredTool) then
		return
	end

	local now = os.clock()
	if not elecCooldowns[plr] then
		elecCooldowns[plr] = {}
	end
	if (elecCooldowns[plr][action] or 0) > now then
		sendCooldown(plr, requiredTool, elecCooldowns[plr][action])
		return
	end

	local char = getCharacter(plr)
	local root = getRoot(char)
	local hum, targetRoot = findTargetHumanoid(plr, hit, hitPos, ELEC_RANGE, false)
	if not char or not root then
		return
	end

	local function cooldownFor(key, duration)
		elecCooldowns[plr][key] = now + getCooldownDuration(plr, duration)
		sendCooldownStarted(plr, requiredTool, getCooldownDuration(plr, duration))
	end

	if action == "Strike" and hum and targetRoot then
		makeLightningVFX(root.Position, targetRoot.Position, Color3.fromRGB(255, 235, 80), 1)
		hum:TakeDamage((hum.MaxHealth * 0.10 + 35) * getDamageMultiplier(plr))
		stunHumanoid(hum, 1.25)
		cooldownFor("Strike", ELEC_STRIKE_COOLDOWN)
	elseif action == "Stun" and hum and targetRoot then
		makeLightningVFX(root.Position, targetRoot.Position, Color3.fromRGB(120, 220, 255), 1.2)
		hum:TakeDamage((hum.MaxHealth * 0.06 + 18) * getDamageMultiplier(plr))
		stunHumanoid(hum, 2.5)
		cooldownFor("Stun", ELEC_STUN_COOLDOWN)
	elseif action == "Discharge" then
		local dischargeTargets = collectElectricTargets(char, root.Position, 32)
		makeLightningVFX(root.Position, root.Position + Vector3.new(0, 12, 0), Color3.fromRGB(255, 255, 120), 2)
		for index, target in ipairs(dischargeTargets) do
			local percent = math.max(ELECTRIC_DISCHARGE_MIN_PERCENT, ELECTRIC_DISCHARGE_MAX_PERCENT - ((index - 1) * ELECTRIC_DISCHARGE_FALLOFF))
			makeLightningVFX(root.Position, target.root.Position, Color3.fromRGB(255, 235, 80), 0.8)
			target.hum:TakeDamage(target.hum.MaxHealth * percent)
			stunHumanoid(target.hum, 1.0)
		end
		cooldownFor("Discharge", ELEC_DISCHARGE_COOLDOWN)
