function fireLaser(plr, targetPos)
	if not hasPower(plr, "LaserEyes") or not hasEquippedTool(plr, LASER_TOOL_NAME) then
		cleanupLaserState(plr)
		return
	end

	if typeof(targetPos) ~= "Vector3" then
		return
	end

	local now = os.clock()
	if (laserCooldownUntil[plr] or 0) > now then
		sendCooldown(plr, "Laser Eyes", laserCooldownUntil[plr])
		return
	end

	if lastLaserFireAt[plr] and now - lastLaserFireAt[plr] < LASER_COOLDOWN then
		return
	end
	lastLaserFireAt[plr] = now

	local char = getCharacter(plr)
	if not char then
		return
	end

	local state = ensureLaserState(plr)
	if not state then
		return
	end

	if state.startedAt and now - state.startedAt >= LASER_OVERHEAT_TIME then
		cleanupLaserState(plr)
		local duration = getCooldownDuration(plr, LASER_OVERHEAT_COOLDOWN)
		laserCooldownUntil[plr] = now + duration
		sendCooldownStarted(plr, "Laser Eyes", duration)
		return
	end

	local leftEye = state.head:FindFirstChild("VLaserLeftEye")
	local rightEye = state.head:FindFirstChild("VLaserRightEye")
	if not leftEye or not rightEye then
		return
	end

	local startPos = (leftEye.WorldPosition + rightEye.WorldPosition) * 0.5
	local endPos, hitPart = getLaserEnd(char, startPos, targetPos)

	state.targetPart.CFrame = CFrame.new(endPos)
	state.activeUntil = now + LASER_ACTIVE_TIME
	setLaserEnabled(state, true)

	if hitPart then
		local hum = humanoidFromHit(hitPart, char)
		if hum then
			local lastDamage = lastLaserDamageAt[plr] or (now - LASER_COOLDOWN)
			local damageDt = math.clamp(now - lastDamage, LASER_COOLDOWN, 0.14)
			lastLaserDamageAt[plr] = now
			local damage = (LASER_DPS * damageDt) + (hum.MaxHealth * LASER_MAX_HEALTH_DPS * damageDt)
			hum:TakeDamage(damage * getDamageMultiplier(plr))
		end

		if math.random(1, 5) == 1 then
			makeImpactSpark(endPos, state.light.Color)
		end
	end
end

function restoreInvisibility(plr)
	local char = getCharacter(plr)
	if not char then
		invisiblePlayers[plr] = nil
		return
	end

	local original = invisibilityOriginals[char]
	if original then
		for inst, props in pairs(original) do
			if inst and inst.Parent then
				for prop, value in pairs(props) do
					pcall(function()
						inst[prop] = value
					end)
				end
			end
		end
		invisibilityOriginals[char] = nil
	end

	local hum = getHumanoid(char)
	if hum and displayDistanceOriginals[char] then
		hum.DisplayDistanceType = displayDistanceOriginals[char]
	end

	displayDistanceOriginals[char] = nil
	char:SetAttribute("VInvisible", false)
	invisiblePlayers[plr] = nil
end

function setInvisibility(plr, enabled)
	if not hasPower(plr, "Translucent") then
		restoreInvisibility(plr)
		return
	end

	local char = getCharacter(plr)
	if not char then
		return
	end

	if not enabled then
		restoreInvisibility(plr)
		sendNotice(plr, "Invisibility off")
		return
	end

	local original = {}
	for _, inst in ipairs(char:GetDescendants()) do
		if inst:IsA("BasePart") then
			original[inst] = {
				Transparency = inst.Transparency,
			}
			inst.Transparency = 1
		elseif inst:IsA("Decal") or inst:IsA("Texture") then
			original[inst] = {
				Transparency = inst.Transparency,
			}
			inst.Transparency = 1
		elseif inst:IsA("ParticleEmitter") or inst:IsA("Trail") or inst:IsA("Beam") then
			original[inst] = {
				Enabled = inst.Enabled,
			}
			inst.Enabled = false
		end
	end

	local hum = getHumanoid(char)
	if hum then
		displayDistanceOriginals[char] = hum.DisplayDistanceType
		hum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
	end

	invisibilityOriginals[char] = original
	char:SetAttribute("VInvisible", true)
	invisiblePlayers[plr] = true
	sendNotice(plr, "Invisibility on")
end

function setSpeed(plr, speed)
	if not hasPower(plr, "SuperSpeed") then
		return
	end

	speed = tonumber(speed)
	if speed ~= 50 and speed ~= 100 and speed ~= 250 then
		return
	end

	if (speedCooldownUntil[plr] or 0) > os.clock() then
		sendCooldown(plr, "Speed", speedCooldownUntil[plr])
		return
	end

	if not hasTool(plr, "Speed " .. tostring(speed)) then
		return
	end

	local char = getCharacter(plr)
	local hum = getHumanoid(char)
	if not hum or hum.Health <= 0 then
		return
	end

	rememberBaseWalkSpeed(hum)
	hum.WalkSpeed = speed
	sendNotice(plr, "Speed set to " .. tostring(speed))

	if speed == 250 then
		speed250Until[plr] = os.clock() + SPEED_HEART_ATTACK_DURATION
	else
		speed250Until[plr] = nil
