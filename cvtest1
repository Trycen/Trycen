RunService.Heartbeat:Connect(function(dt)
	local now = os.clock()

	for plr, state in pairs(laserStates) do
		if now > state.activeUntil then
			setLaserEnabled(state, false)
		end
	end

	for _, plr in ipairs(Players:GetPlayers()) do
		applySpeedDamage(plr)
		if hasPower(plr, "Gravity") then
			applyGravityPassive(plr)
		end
		applyPassiveRegen(plr, dt)
		updateWeepingRegeneration(plr)
		updateV1Regeneration(plr)
		updateBloodDrain(plr)
	end
end)

