function applySpeedDamage(plr)
	if not hasPower(plr, "SuperSpeed") then
		return
	end

	local char = getCharacter(plr)
	local hum = getHumanoid(char)
	local root = getRoot(char)
	if not char or not hum or hum.Health <= 0 or not root then
		return
	end

	if hum.Sit or hum.SeatPart then
		return
	end

	local now = os.clock()

	if speed250Until[plr] and now >= speed250Until[plr] then
		applySpeedHeartAttack(plr)
	end

	if (speedBleedUntil[plr] or 0) > now then
		local bleedDt = math.max(0, math.min(1, SPEED_SCAN_INTERVAL))
		local bleed = math.max(0.5, hum.MaxHealth * 0.008 * bleedDt)
		hum:TakeDamage(math.min(bleed, math.max(hum.Health - 1, 0)))
	end

	if nextSpeedScanAt[plr] and now < nextSpeedScanAt[plr] then
		return
	end
	nextSpeedScanAt[plr] = now + SPEED_SCAN_INTERVAL

	local velocity = root.AssemblyLinearVelocity.Magnitude
	if velocity <= 40 then
		return
	end

	local damage = math.floor(math.clamp(velocity, 0, SPEED_DAMAGE_CAP))
	if damage < SPEED_MIN_DAMAGE then
		return
	end

	local params = OverlapParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = { char }

	local parts = Workspace:GetPartBoundsInRadius(root.Position, SPEED_HIT_RADIUS, params)
	local seen = {}

	for _, part in ipairs(parts) do
		local model = part:FindFirstAncestorOfClass("Model")
		if model and model ~= char and not seen[model] then
			seen[model] = true
			local targetHum = getHumanoid(model)
			if targetHum and targetHum.Health > 0 then
				local hitTimes = speedHitTimes[plr]
				if not hitTimes then
					hitTimes = {}
					speedHitTimes[plr] = hitTimes
				end

				local nextAllowed = hitTimes[targetHum] or 0
				if now >= nextAllowed then
					hitTimes[targetHum] = now + getCooldownDuration(plr, SPEED_HIT_COOLDOWN)
					targetHum:TakeDamage(damage * getDamageMultiplier(plr))
				end
			end
		end
	end
end

function updateV1Regeneration(plr)
	if not hasV1(plr) then
		return
	end

	local now = os.clock()
	if v1RegenAt[plr] and now < v1RegenAt[plr] then
		return
	end
	v1RegenAt[plr] = now + 1

	local char = getCharacter(plr)
	local hum = getHumanoid(char)
	if hum and hum.Health > 0 and hum.Health < hum.MaxHealth then
		hum.Health = math.min(hum.MaxHealth, hum.Health + hum.MaxHealth * V1_REGEN_PERCENT_PER_SECOND)
	end
end

function givePowerTools(plr, powerName, persist)
	if powerName == "LaserEyes" then
		givePowerTool(plr, LASER_TOOL_NAME, persist)
	elseif powerName == "SuperSpeed" then
		givePowerTool(plr, "Speed 50", persist)
		givePowerTool(plr, "Speed 100", persist)
		givePowerTool(plr, "Speed 250", persist)
		givePowerTool(plr, SPEED_RESET_TOOL_NAME, persist)

		local char = getCharacter(plr)
		local hum = getHumanoid(char)
		if hum then
			rememberBaseWalkSpeed(hum)
			if hum.WalkSpeed < 50 then
				hum.WalkSpeed = 50
			end
		end
	elseif powerName == "Translucent" then
		givePowerTool(plr, INVIS_TOOL_NAME, persist)
	elseif powerName == "Teleportation" then
		givePowerTool(plr, TELEPORT_TOOL_NAME, persist)
	elseif powerName == "Healing" then
		givePowerTool(plr, HEAL_5_TOOL_NAME, persist)
		givePowerTool(plr, HEAL_25_TOOL_NAME, persist)
		givePowerTool(plr, WEEPING_REGEN_TOOL_NAME, persist)
	elseif powerName == "Electricity" then
		givePowerTool(plr, ELEC_STRIKE_TOOL_NAME, persist)
		givePowerTool(plr, ELEC_STUN_TOOL_NAME, persist)
		givePowerTool(plr, ELEC_DISCHARGE_TOOL_NAME, persist)
		if hasV1(plr) then
			givePowerTool(plr, ELEC_ULT_TOOL_NAME, persist)
		end
	elseif powerName == "Gravity" then
		givePowerTool(plr, GRAVITY_PUSH_TOOL_NAME, persist)
		givePowerTool(plr, GRAVITY_PULL_TOOL_NAME, persist)
		givePowerTool(plr, GRAVITY_SUSPEND_TOOL_NAME, persist)
		givePowerTool(plr, GRAVITY_SLAM_TOOL_NAME, persist)
	elseif powerName == "BloodManipulation" then
		givePowerTool(plr, BLOOD_TOOL_NAME, persist)
		givePowerTool(plr, BLOOD_SEIZURE_TOOL_NAME, persist)
		givePowerTool(plr, BLOOD_LIMB_TOOL_NAME, persist)
		if hasV1(plr) then
			givePowerTool(plr, BLOOD_POP_TOOL_NAME, persist)
		end
	elseif powerName == "Vessel" then
		return
	end
end

function refreshPlayerPower(plr)
	local char = getCharacter(plr)
	clearPowerTools(plr)
	cleanupLaserState(plr)
	restoreInvisibility(plr)
	cleanupGravityAssist(plr)
	stopBloodDrain(plr, false)
	cleanupSuspension(plr, false)
	activeWeepingRegens[plr] = nil

	if not char then
		return
	end

	restoreBaseWalkSpeed(char)
	restoreBaseJump(char)

	if not hasAnyPower(plr) and not hasV1(plr) then
		restoreBaseHealth(char)
		return
	end

	local set = getPowerSet(plr)
	local totalBonus = 0

	for _, powerName in ipairs(POWER_ORDER) do
		if set[powerName] then
			totalBonus = totalBonus + POWERS[powerName].BonusHealth
		end
	end

	local healthMultiplier = 1
	if hasV1(plr) then
		healthMultiplier = V1_HEALTH_MULTIPLIER
	end

	applyHealthBonus(char, totalBonus, healthMultiplier)

	for _, powerName in ipairs(POWER_ORDER) do
		if set[powerName] then
			givePowerTools(plr, powerName, hasPermanentPower(plr, powerName))
		end
	end

	if set.Gravity then
		applyGravityPassive(plr)
	end
end

function clearV(sourcePlr, targetPlr)
	if not targetPlr then
		return
	end

	compoundPowersByUserId[targetPlr.UserId] = nil
	tempPowersByPlayer[targetPlr] = nil
	v1ByUserId[targetPlr.UserId] = nil
	refreshPlayerPower(targetPlr)
	sendNotice(targetPlr, "All V powers cleared")

	if sourcePlr and sourcePlr ~= targetPlr then
		sendNotice(sourcePlr, targetPlr.Name .. "'s V was cleared")
	end
end

function overdosePlayer(sourcePlr, targetPlr, chance)
	compoundPowersByUserId[targetPlr.UserId] = nil
	tempPowersByPlayer[targetPlr] = nil
	v1ByUserId[targetPlr.UserId] = nil
	refreshPlayerPower(targetPlr)

	local hum = getHumanoid(getCharacter(targetPlr))
	if hum then
		hum.Health = 0
	end

	sendNotice(targetPlr, "V overdose: all powers lost")
	if sourcePlr and sourcePlr ~= targetPlr then
		sendNotice(sourcePlr, targetPlr.Name .. " overdosed (" .. tostring(math.floor(chance * 100)) .. "% roll)")
	end
end

function addPowerDose(plr, isCompound, powerName)
	if isCompound then
		local list = compoundPowersByUserId[plr.UserId]
		if not list then
			list = {}
			compoundPowersByUserId[plr.UserId] = list
		end
		table.insert(list, powerName)
	else
		local list = tempPowersByPlayer[plr]
		if not list then
			list = {}
			tempPowersByPlayer[plr] = list
		end
		table.insert(list, powerName)
	end
end

function grantV(sourcePlr, targetPlr, isCompound, requestedPower, skipOverdose)
	if not targetPlr or not targetPlr.Parent then
		return
	end

	local powerName = requestedPower
	if powerName ~= "ALL_POWERS" and not POWERS[powerName] then
		powerName = pickPowerForPlayer(targetPlr)
	end

	if powerName == "Vessel" and not canGrantVessel(targetPlr) then
		sendNotice(targetPlr, "Vessel is locked until your powers are cleared")
		if sourcePlr and sourcePlr ~= targetPlr then
			sendNotice(sourcePlr, targetPlr.Name .. " cannot receive Vessel yet")
		end
		return
	end

	local afterDoseCount = countPowerDoses(targetPlr) + 1
	if powerName == "ALL_POWERS" then
		for _, possiblePower in ipairs(POWER_ORDER) do
			addPowerDose(targetPlr, isCompound, possiblePower)
		end
		afterDoseCount = countPowerDoses(targetPlr)
	else
		addPowerDose(targetPlr, isCompound, powerName)
	end

	refreshPlayerPower(targetPlr)

	local sourceLabel = isCompound and "Compound V" or "Temp V"
	local powerLabel = powerName == "ALL_POWERS" and "All Powers" or POWERS[powerName].DisplayName
	sendNotice(targetPlr, sourceLabel .. ": " .. powerLabel)

	if sourcePlr and sourcePlr ~= targetPlr then
		sendNotice(sourcePlr, targetPlr.Name .. " got " .. sourceLabel .. " (" .. powerLabel .. ")")
	end

	if powerName == "Vessel" then
		sendNotice(targetPlr, "Vessel active: overdose risk is reduced 10x until you gain another power.")
	end

	if not skipOverdose then
		local overdoseChance = 0
		if afterDoseCount > 1 then
			overdoseChance = math.clamp((afterDoseCount - 1) * OVERDOSE_CHANCE_PER_EXTRA_DOSE, 0, OVERDOSE_MAX_CHANCE)
		end
		if hasVessel(targetPlr) then
			overdoseChance = overdoseChance * VESSEL_OVERDOSE_MULTIPLIER
		end
		if overdoseChance > 0 and math.random() < overdoseChance then
			overdosePlayer(sourcePlr, targetPlr, overdoseChance)
		end
	end
end

function applyV1(sourcePlr, targetPlr, requestedPower, bypassFatality)
	if not targetPlr or not targetPlr.Parent then
		return
	end

	local hadNoPowers = not hasAnyPower(targetPlr)
	local hasTempPower = false
	local tempList = getTempList(targetPlr)
	if tempList and #tempList > 0 then
		hasTempPower = true
	end

	local fatalityChance = V1_FATALITY_CHANCE
	if hasTempPower then
		fatalityChance = V1_TEMP_FATALITY_CHANCE
	end

	if not bypassFatality and math.random() < fatalityChance then
		overdosePlayer(sourcePlr, targetPlr, fatalityChance)
		sendNotice(targetPlr, "Compound V1 failed")
		return
	end

	v1ByUserId[targetPlr.UserId] = true

	if hadNoPowers then
		grantV(sourcePlr, targetPlr, true, requestedPower, true)
	else
		refreshPlayerPower(targetPlr)
	end

	sendNotice(targetPlr, "Compound V1 active")
	if sourcePlr and sourcePlr ~= targetPlr then
		sendNotice(sourcePlr, targetPlr.Name .. " received Compound V1")
	end
end

function playerFromHit(hit)
	if typeof(hit) ~= "Instance" then
		return nil
	end

	local model = hit:FindFirstAncestorOfClass("Model")
	if not model then
		return nil
	end

	return Players:GetPlayerFromCharacter(model)
end

function playerFromHitOrPosition(sourcePlr, hit, hitPos)
	local hitPlayer = playerFromHit(hit)
	if hitPlayer then
		return hitPlayer
	end

	local hum = findTargetHumanoid(sourcePlr, hit, hitPos, INJECT_RANGE, true)
	if hum then
		return Players:GetPlayerFromCharacter(hum.Parent)
	end

	return nil
end

function targetInInjectionRange(ownerPlr, targetPlr)
	if ownerPlr == targetPlr then
		return true
	end

	local ownerRoot = getRoot(getCharacter(ownerPlr))
	local targetRoot = getRoot(getCharacter(targetPlr))
	if not ownerRoot or not targetRoot then
		return false
	end

	return (ownerRoot.Position - targetRoot.Position).Magnitude <= INJECT_RANGE
end

function findPlayerByText(text)
	if type(text) ~= "string" or text == "" then
		return nil
	end

	local lower = string.lower(text)
	if lower == "me" then
		return nil
	end

	for _, plr in ipairs(Players:GetPlayers()) do
		if string.lower(plr.Name) == lower or string.lower(plr.DisplayName) == lower then
			return plr
		end
	end

	for _, plr in ipairs(Players:GetPlayers()) do
		if string.sub(string.lower(plr.Name), 1, #lower) == lower
			or string.sub(string.lower(plr.DisplayName), 1, #lower) == lower then
			return plr
		end
	end

	return nil
end

function trimText(text)
	return string.match(text or "", "^%s*(.-)%s*$")
end

function insertUniquePlayer(list, seen, plr)
	if plr and not seen[plr] then
		seen[plr] = true
		table.insert(list, plr)
	end
end

function resolveTargetList(ownerPlr, text)
	local targets = {}
	local seen = {}

	if not text or text == "" then
		insertUniquePlayer(targets, seen, ownerPlr)
		return targets
	end

	local lower = string.lower(text)
	if lower == "me" then
		insertUniquePlayer(targets, seen, ownerPlr)
		return targets
	elseif lower == "all" then
		for _, plr in ipairs(Players:GetPlayers()) do
			insertUniquePlayer(targets, seen, plr)
		end
		return targets
	elseif lower == "others" then
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr ~= ownerPlr then
				insertUniquePlayer(targets, seen, plr)
			end
		end
		return targets
	end

	for piece in string.gmatch(text, "[^,]+") do
		local name = trimText(piece)
		local pieceLower = string.lower(name)
		if pieceLower == "me" then
			insertUniquePlayer(targets, seen, ownerPlr)
		elseif pieceLower == "all" then
			for _, plr in ipairs(Players:GetPlayers()) do
				insertUniquePlayer(targets, seen, plr)
			end
		elseif pieceLower == "others" then
			for _, plr in ipairs(Players:GetPlayers()) do
				if plr ~= ownerPlr then
					insertUniquePlayer(targets, seen, plr)
				end
			end
		else
			local found = findPlayerByText(name)
			if found then
				insertUniquePlayer(targets, seen, found)
			end
		end
	end

	return targets
end

function looksLikeTargetArg(ownerPlr, text)
	if type(text) ~= "string" or text == "" then
		return false
	end

	local lower = string.lower(text)
	if lower == "me" or lower == "all" or lower == "others" then
		return true
	end

	if string.find(text, ",") then
		return true
	end

	return findPlayerByText(text) ~= nil
end

function wordsFromMessage(message)
	local words = {}
	for word in string.gmatch(message, "%S+") do
		table.insert(words, word)
	end

	return words
end

function parseTargetPowerAmount(ownerPlr, words)
	local targets = { ownerPlr }
	local index = 2

	if words[index] then
		if looksLikeTargetArg(ownerPlr, words[index]) then
			targets = resolveTargetList(ownerPlr, words[index])
			if #targets <= 0 then
				sendNotice(ownerPlr, "No targets found: " .. words[index])
				return nil, nil, nil
			end
			index = index + 1
		end
	end

	local powerName = nil
	if words[index] and not tonumber(words[index]) then
		if isRandomPowerWord(words[index]) then
			powerName = nil
		elseif isAllPowerWord(words[index]) then
			powerName = "ALL_POWERS"
		else
			powerName = resolvePowerName(words[index])
			if not powerName then
				sendNotice(ownerPlr, "Unknown power: " .. words[index])
				return nil, nil, nil
			end
		end
		index = index + 1
	end

	local amount = tonumber(words[index]) or 1
	amount = math.clamp(math.floor(amount), 1, 20)

	return targets, powerName, amount
end

function handleOwnerChat(plr, message)
	if not isOwner(plr) then
		return
	end

	local words = wordsFromMessage(message)
	local command = words[1] and string.lower(words[1]) or ""

	if command == "!compound" or command == "!cv" then
		local targets, powerName, amount = parseTargetPowerAmount(plr, words)
		if targets then
			for _, targetPlr in ipairs(targets) do
				for _ = 1, amount do
					grantV(plr, targetPlr, true, powerName, true)
				end
			end
		end
	elseif command == "!temp" or command == "!tv" then
		local targets, powerName, amount = parseTargetPowerAmount(plr, words)
		if targets then
			for _, targetPlr in ipairs(targets) do
				for _ = 1, amount do
					grantV(plr, targetPlr, false, powerName, true)
				end
			end
		end
	elseif command == "!givecompound" or command == "!givecv" then
		local targets, powerName, amount = parseTargetPowerAmount(plr, words)
		if targets then
			for _, targetPlr in ipairs(targets) do
				local given = giveVial(targetPlr, true, powerName, amount)
				sendNotice(plr, "Gave " .. tostring(given) .. " Compound V to " .. targetPlr.Name)
				if targetPlr ~= plr then
					sendNotice(targetPlr, "You received Compound V")
				end
			end
		end
	elseif command == "!givetemp" or command == "!givetv" then
		local targets, powerName, amount = parseTargetPowerAmount(plr, words)
		if targets then
			for _, targetPlr in ipairs(targets) do
				local given = giveVial(targetPlr, false, powerName, amount)
				sendNotice(plr, "Gave " .. tostring(given) .. " Temp V to " .. targetPlr.Name)
				if targetPlr ~= plr then
					sendNotice(targetPlr, "You received Temp V")
				end
			end
		end
	elseif command == "!givev1" then
		local targets, powerName, amount = parseTargetPowerAmount(plr, words)
		if targets then
			for _, targetPlr in ipairs(targets) do
				local given = giveV1Vial(targetPlr, powerName, amount)
				sendNotice(plr, "Gave " .. tostring(given) .. " Compound V1 to " .. targetPlr.Name)
				if targetPlr ~= plr then
					sendNotice(targetPlr, "You received Compound V1")
				end
			end
		end
	elseif command == "!v1" then
		local targets, powerName = parseTargetPowerAmount(plr, words)
		if targets then
			for _, targetPlr in ipairs(targets) do
				applyV1(plr, targetPlr, powerName, true)
			end
		end
	elseif command == "!clearv" then
		local targets = resolveTargetList(plr, words[2] or "me")
		if targets and #targets > 0 then
			for _, targetPlr in ipairs(targets) do
				clearV(plr, targetPlr)
			end
		else
			sendNotice(plr, "Could not find player: " .. tostring(words[2]))
		end
	elseif command == "!cmds" then
		showCommandList(plr)
	end
end

function consumeVTool(plr, tool)
	if isOwner(plr) then
		return
	end

	if tool and tool.Parent then
		tool:Destroy()
	end
end

function useVTool(plr, toolName, hit, hitPos)
	if toolName ~= COMPOUND_TOOL_NAME and toolName ~= TEMP_TOOL_NAME and toolName ~= V1_TOOL_NAME then
		return
	end

	local tool = getEquippedTool(plr, toolName)
	if not tool then
		return
	end

	local isCompound = toolName == COMPOUND_TOOL_NAME or toolName == V1_TOOL_NAME
	local targetPlr = plr

	if isOwner(plr) then
		targetPlr = playerFromHitOrPosition(plr, hit, hitPos) or plr
		if not targetInInjectionRange(plr, targetPlr) then
			sendNotice(plr, "Target is too far away")
			return
		end
	end

	local forcedPower = tool:GetAttribute("VForcedPower")
	if isRandomPowerWord(forcedPower) then
		forcedPower = nil
	elseif isAllPowerWord(forcedPower) or forcedPower == "ALL_POWERS" then
		forcedPower = "ALL_POWERS"
	else
		forcedPower = resolvePowerName(forcedPower)
	end

	consumeVTool(plr, tool)
	local targetRoot = getRoot(getCharacter(targetPlr))
	if targetRoot then
		if toolName == COMPOUND_TOOL_NAME then
			makeSparkleBurst(targetRoot.Position, Color3.fromRGB(0, 255, 255), 50, 1)
		elseif toolName == TEMP_TOOL_NAME then
			makeSparkleBurst(targetRoot.Position, Color3.fromRGB(0, 85, 35), 50, 1)
		else
			makeSparkleBurst(targetRoot.Position, Color3.fromRGB(0, 20, 150), 60, 1.15)
		end
	end

	if toolName == V1_TOOL_NAME then
		applyV1(plr, targetPlr, forcedPower, false)
	else
		grantV(plr, targetPlr, isCompound, forcedPower, false)
	end
end

function hookCharacter(plr, char)
	task.wait(0.2)
	ensureOwnerInjectorTools(plr)
	refreshPlayerPower(plr)

	local hum = getHumanoid(char)
	if hum then
		hum.Died:Connect(function()
			cleanupLaserState(plr)
			restoreInvisibility(plr)
			cleanupGravityAssist(plr)
			cleanupSuspension(plr, false)
			stopBloodDrain(plr, false)
			activeWeepingRegens[plr] = nil
			clearPowerTools(plr)

			if tempPowersByPlayer[plr] then
				tempPowersByPlayer[plr] = nil
				sendNotice(plr, "Temp V wore off")
			end
		end)
	end
end

function hookPlayer(plr)
	if hookedPlayers[plr] then
		return
	end

	hookedPlayers[plr] = true
	plr.Chatted:Connect(function(message)
		handleOwnerChat(plr, message)
	end)

	task.defer(function()
		ensureOwnerInjectorTools(plr)
		refreshPlayerPower(plr)
	end)

	plr.CharacterAdded:Connect(function(char)
		hookCharacter(plr, char)
	end)

	if plr.Character then
		task.spawn(hookCharacter, plr, plr.Character)
	end
end

