end

function getSpeedRecoveryTarget()
	return math.random(SPEED_NORMAL_MIN, SPEED_NORMAL_MAX)
end

function applySpeedHeartAttack(plr)
	local char = getCharacter(plr)
	local hum = getHumanoid(char)
	local root = getRoot(char)
	if not hum or hum.Health <= 0 then
		return
	end

	local now = os.clock()
	speedCooldownUntil[plr] = now + SPEED_HEART_ATTACK_COOLDOWN
	speedBleedUntil[plr] = now + SPEED_HEART_ATTACK_BLEED_DURATION
	speed250Until[plr] = nil

	rememberBaseWalkSpeed(hum)
	hum.WalkSpeed = 15
	if root then
		makeSparkleBurst(root.Position, Color3.fromRGB(255, 65, 65), 35, 1.2)
	end
	sendNotice(plr, "Heart attack: speed locked at 15 for 1 minute")
end

function restoreSpeedNormal(plr)
	local char = getCharacter(plr)
	local hum = getHumanoid(char)
	if not hum or hum.Health <= 0 then
		return
	end

	local now = os.clock()
	if (speedCooldownUntil[plr] or 0) > now then
		speedCooldownUntil[plr] = nil
	end
	speed250Until[plr] = nil
	speedBleedUntil[plr] = nil

	local target = getSpeedRecoveryTarget()
	rememberBaseWalkSpeed(hum)
	hum.WalkSpeed = target
	sendNotice(plr, "Speed normalized to " .. tostring(target))
end

function sendCooldown(plr, abilityName, readyAt)
	local remaining = math.max(readyAt - os.clock(), 0)
	sendNotice(plr, abilityName .. " ready in " .. tostring(math.ceil(remaining)) .. "s")
end

function sendCooldownStarted(plr, abilityName, duration)
	if duration and duration >= 1 then
		sendNotice(plr, abilityName .. " cooldown: " .. tostring(math.ceil(duration)) .. "s")
	end
end

function hasVessel(plr)
	if not plr then
		return false
	end
	return listHasPower(getPowerSet(plr), "Vessel")
end

function onlyHasPower(plr, powerName)
	local set = getPowerSet(plr)
	local hasAny = false
	for power in pairs(set) do
		hasAny = true
		if power ~= powerName then
			return false
		end
	end
	return hasAny and set[powerName] == true
end

function canGrantVessel(plr)
	local set = getPowerSet(plr)
	for power in pairs(set) do
		if power ~= "Vessel" then
			return false
		end
	end
	return true
end

function getPassiveRegenRate(plr)
	if hasV1(plr) then
		return V1_REGEN_PERCENT_PER_SECOND
	end
	if hasVessel(plr) then
		return VESSEL_REGEN_PERCENT_PER_SECOND
	end
	if hasAnyPower(plr) then
		return PASSIVE_REGEN_PERCENT_PER_SECOND
	end
	return 0
end

