function updateWeepingRegeneration(plr)
	local data = activeWeepingRegens[plr]
	if not data then
		return
	end

	local now = os.clock()
	if now >= data.expiresAt then
		activeWeepingRegens[plr] = nil
		return
	end

	if now < data.nextTick then
		return
	end

	data.nextTick = now + 1

	local char = getCharacter(plr)
	local root = getRoot(char)
	if not root then
		activeWeepingRegens[plr] = nil
		return
	end

	makeSparkleBurst(root.Position, Color3.fromRGB(80, 255, 160), 14, 0.55)

	local params = OverlapParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = {}

	local parts = Workspace:GetPartBoundsInRadius(root.Position, WEEPING_REGEN_RADIUS, params)
	local seen = {}
	for _, part in ipairs(parts) do
		local model = part:FindFirstAncestorOfClass("Model")
		if model and not seen[model] then
			seen[model] = true
			local hum = getHumanoid(model)
			if hum and hum.Health > 0 then
				hum.Health = math.min(hum.MaxHealth, hum.Health + hum.MaxHealth * WEEPING_REGEN_PERCENT_PER_SECOND)
			end
		end
	end
end

function cleanupSuspension(plr, slam)
	local data = suspendedTargets[plr]
	if not data then
		return nil, nil
	end

	suspendedTargets[plr] = nil

	if data.bodyPosition and data.bodyPosition.Parent then
		data.bodyPosition:Destroy()
	end

	if data.bodyGyro and data.bodyGyro.Parent then
		data.bodyGyro:Destroy()
	end

	if slam and data.root and data.root.Parent then
		data.root.AssemblyLinearVelocity = Vector3.new(0, -120, 0)
		data.root:ApplyImpulse(Vector3.new(0, -data.root.AssemblyMass * 230, 0))
	end

	return data.humanoid, data.root
end

function getGravityCooldown(plr, key)
	local data = gravityCooldownUntil[plr]
	if not data then
		data = {}
		gravityCooldownUntil[plr] = data
	end

	return data[key] or 0
end

function setGravityCooldown(plr, key, duration)
	local data = gravityCooldownUntil[plr]
	if not data then
		data = {}
		gravityCooldownUntil[plr] = data
	end

	data[key] = os.clock() + duration
end

function gravityAction(plr, action, hit, hitPos)
	if not hasPower(plr, "Gravity") then
		return
	end

	local toolNameByAction = {
		Push = GRAVITY_PUSH_TOOL_NAME,
		Pull = GRAVITY_PULL_TOOL_NAME,
		Suspend = GRAVITY_SUSPEND_TOOL_NAME,
		Slam = GRAVITY_SLAM_TOOL_NAME,
	}

	local requiredTool = toolNameByAction[action]
	if not requiredTool or not hasEquippedTool(plr, requiredTool) then
		return
	end

	local now = os.clock()
	local char = getCharacter(plr)
	local root = getRoot(char)
	if not root then
		return
	end

	if action == "Slam" then
		if getGravityCooldown(plr, "Slam") > now then
			sendCooldown(plr, "Gravity Slam", getGravityCooldown(plr, "Slam"))
			return
		end

		local hum, targetRoot = cleanupSuspension(plr, true)
		if not hum then
			hum, targetRoot = findTargetHumanoid(plr, hit, hitPos, GRAVITY_RANGE, false)
			if targetRoot then
				targetRoot.AssemblyLinearVelocity = Vector3.new(0, -120, 0)
				targetRoot:ApplyImpulse(Vector3.new(0, -targetRoot.AssemblyMass * 230, 0))
			end
		end

		if hum then
			hum:TakeDamage(math.min(250, hum.MaxHealth * 0.18 + 45) * getDamageMultiplier(plr))
			local cooldown = getCooldownDuration(plr, GRAVITY_SLAM_COOLDOWN)
			setGravityCooldown(plr, "Slam", cooldown)
			sendCooldownStarted(plr, "Gravity Slam", cooldown)
		end
		return
	end

	local hum, targetRoot = findTargetHumanoid(plr, hit, hitPos, GRAVITY_RANGE, false)
	if not hum or not targetRoot then
		return
	end

	if action == "Push" then
		if getGravityCooldown(plr, "Push") > now then
			sendCooldown(plr, "Gravity Push", getGravityCooldown(plr, "Push"))
			return
		end

		local direction = targetRoot.Position - root.Position
		if direction.Magnitude < 1 then
			direction = root.CFrame.LookVector
		end

		pcall(function()
			targetRoot:SetNetworkOwner(nil)
		end)
		local bodyVelocity = Instance.new("BodyVelocity")
		bodyVelocity.Name = "VGravityPushVelocity"
		bodyVelocity.MaxForce = Vector3.new(1, 1, 1) * targetRoot.AssemblyMass * 10000
		bodyVelocity.Velocity = (direction.Unit * 105) + Vector3.new(0, 28, 0)
		bodyVelocity.P = 3500
		bodyVelocity.Parent = targetRoot
		Debris:AddItem(bodyVelocity, 0.28)
		targetRoot.AssemblyLinearVelocity = bodyVelocity.Velocity
		makeSparkleBurst(targetRoot.Position, Color3.fromRGB(120, 85, 255), 18, 0.75)
		local cooldown = getCooldownDuration(plr, GRAVITY_PUSH_COOLDOWN)
		setGravityCooldown(plr, "Push", cooldown)
		sendCooldownStarted(plr, "Gravity Push", cooldown)
	elseif action == "Pull" then
		if getGravityCooldown(plr, "Pull") > now then
			sendCooldown(plr, "Gravity Pull", getGravityCooldown(plr, "Pull"))
			return
		end

		local direction = root.Position - targetRoot.Position
		if direction.Magnitude < 1 then
			direction = -root.CFrame.LookVector
		end

		pcall(function()
			targetRoot:SetNetworkOwner(nil)
		end)
		local bodyVelocity = Instance.new("BodyVelocity")
		bodyVelocity.Name = "VGravityPullVelocity"
		bodyVelocity.MaxForce = Vector3.new(1, 1, 1) * targetRoot.AssemblyMass * 10000
		bodyVelocity.Velocity = (direction.Unit * 95) + Vector3.new(0, 22, 0)
		bodyVelocity.P = 3500
		bodyVelocity.Parent = targetRoot
		Debris:AddItem(bodyVelocity, 0.28)
		targetRoot.AssemblyLinearVelocity = bodyVelocity.Velocity
		makeSparkleBurst(targetRoot.Position, Color3.fromRGB(120, 85, 255), 18, 0.75)
		local cooldown = getCooldownDuration(plr, GRAVITY_PULL_COOLDOWN)
		setGravityCooldown(plr, "Pull", cooldown)
		sendCooldownStarted(plr, "Gravity Pull", cooldown)
	elseif action == "Suspend" then
		if getGravityCooldown(plr, "Suspend") > now then
			sendCooldown(plr, "Gravity Suspend", getGravityCooldown(plr, "Suspend"))
			return
		end

		cleanupSuspension(plr, false)

		local bodyPosition = Instance.new("BodyPosition")
		bodyPosition.Name = "VGravitySuspendPosition"
		bodyPosition.Position = targetRoot.Position + Vector3.new(0, 18, 0)
		bodyPosition.MaxForce = Vector3.new(1, 1, 1) * targetRoot.AssemblyMass * 9000
		bodyPosition.P = 7000
		bodyPosition.D = 650
		bodyPosition.Parent = targetRoot

		local bodyGyro = Instance.new("BodyGyro")
		bodyGyro.Name = "VGravitySuspendGyro"
		bodyGyro.CFrame = targetRoot.CFrame
		bodyGyro.MaxTorque = Vector3.new(1, 1, 1) * targetRoot.AssemblyMass * 5000
		bodyGyro.P = 3000
		bodyGyro.D = 400
		bodyGyro.Parent = targetRoot

		targetRoot.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
		suspendedTargets[plr] = {
			humanoid = hum,
			root = targetRoot,
			bodyPosition = bodyPosition,
			bodyGyro = bodyGyro,
			startedAt = now,
		}

		makeSparkleBurst(targetRoot.Position, Color3.fromRGB(120, 85, 255), 26, 0.9)
		local cooldown = getCooldownDuration(plr, GRAVITY_SUSPEND_COOLDOWN)
		setGravityCooldown(plr, "Suspend", cooldown)
		sendCooldownStarted(plr, "Gravity Suspend", cooldown)
		task.delay(GRAVITY_SUSPEND_DURATION, function()
			local data = suspendedTargets[plr]
			if data and data.bodyPosition == bodyPosition then
				cleanupSuspension(plr, false)
			end
		end)
	end
end

function applyGravityPassive(plr)
	if not hasPower(plr, "Gravity") then
		cleanupGravityAssist(plr)
		return
	end

	local char = getCharacter(plr)
	local hum = getHumanoid(char)
	local root = getRoot(char)
	if not hum or not root then
		return
	end

	if hum.Sit or hum.SeatPart then
		cleanupGravityAssist(plr)
		return
	end

	rememberBaseJump(hum)
	hum.UseJumpPower = true
	hum.JumpPower = math.max(hum.JumpPower, (hum:GetAttribute("VBaseJumpPower") or 50) + 42)
	hum.JumpHeight = math.max(hum.JumpHeight, (hum:GetAttribute("VBaseJumpHeight") or 7.2) + 6)

	local attachment = root:FindFirstChild("VGravityAttachment")
	if not attachment then
		attachment = Instance.new("Attachment")
		attachment.Name = "VGravityAttachment"
		attachment.Parent = root
	end

	local force = root:FindFirstChild("VGravityLift")
	if not force then
		force = Instance.new("VectorForce")
		force.Name = "VGravityLift"
		force.RelativeTo = Enum.ActuatorRelativeTo.World
		force.Attachment0 = attachment
		force.Parent = root
	end

	force.Enabled = true
	force.Force = Vector3.new(0, root.AssemblyMass * Workspace.Gravity * 0.32, 0)
end

function getPlayerFromHumanoid(hum)
	if not hum or not hum.Parent then
		return nil
	end

	return Players:GetPlayerFromCharacter(hum.Parent)
end

function isSupeHumanoid(hum)
	local targetPlr = getPlayerFromHumanoid(hum)
	if not targetPlr then
		return false
	end

	return hasAnyPower(targetPlr) or hasV1(targetPlr)
end

function restoreStun(hum)
	local data = stunnedTargets[hum]
	if not data then
		return
	end

	stunnedTargets[hum] = nil

	if hum and hum.Parent then
		hum.WalkSpeed = data.WalkSpeed or hum.WalkSpeed
		hum.JumpPower = data.JumpPower or hum.JumpPower
		hum.JumpHeight = data.JumpHeight or hum.JumpHeight
		hum.AutoRotate = data.AutoRotate
		hum.PlatformStand = false
	end
end

function stunHumanoid(hum, duration)
	if not hum or hum.Health <= 0 then
		return
	end

	if not stunnedTargets[hum] then
		stunnedTargets[hum] = {
			WalkSpeed = hum.WalkSpeed,
			JumpPower = hum.JumpPower,
			JumpHeight = hum.JumpHeight,
			AutoRotate = hum.AutoRotate,
		}
	end

	hum.WalkSpeed = 0
	hum.JumpPower = 0
	hum.JumpHeight = 0
	hum.AutoRotate = false
	hum.PlatformStand = true

	task.delay(duration, function()
		restoreStun(hum)
	end)
end

function tryPopHead(ownerPlr, hum, root, fromDrain)
	if not hum or hum.Health <= 0 or not hum.Parent then
		return false
	end

	if isSupeHumanoid(hum) then
		if not fromDrain then
			sendNotice(ownerPlr, "Pop Heads does not work on supes")
		end
		return false
	end

	local head = hum.Parent:FindFirstChild("Head")
	if head and head:IsA("BasePart") then
		makeSparkleBurst(head.Position, Color3.fromRGB(190, 0, 35), 45, 1.1)
		head:BreakJoints()
		head.Transparency = 1
		head.CanCollide = false
	else
		local popRoot = root or getRoot(hum.Parent)
		if popRoot then
			makeSparkleBurst(popRoot.Position, Color3.fromRGB(190, 0, 35), 35, 1)
		end
	end

	hum.Health = 0
	return true
end

function stopBloodDrain(plr, applyCooldown)
	local session = bloodSessions[plr]
	if not session then
		return
	end

	bloodSessions[plr] = nil

	if session.targetHumanoid and session.targetHumanoid.Parent and session.oldWalkSpeed then
		session.targetHumanoid.WalkSpeed = session.oldWalkSpeed
	end

	if applyCooldown then
		local duration = math.max(os.clock() - session.startedAt, 0)
		local cooldown = getCooldownDuration(plr, BLOOD_BASE_COOLDOWN + duration * BLOOD_EXTRA_COOLDOWN_PER_SECOND)
		bloodCooldownUntil[plr] = os.clock() + cooldown
		sendCooldownStarted(plr, "Blood Drain", cooldown)
	end
end

function startBloodDrain(plr, hit, hitPos)
	if not hasPower(plr, "BloodManipulation") or not hasEquippedTool(plr, BLOOD_TOOL_NAME) then
		return
	end

	local now = os.clock()
	if (bloodCooldownUntil[plr] or 0) > now then
		sendCooldown(plr, "Blood Drain", bloodCooldownUntil[plr])
		return
	end

	local hum, root = findTargetHumanoid(plr, hit, hitPos, BLOOD_RANGE, false)
	if not hum or not root then
		return
	end

	bloodSessions[plr] = {
		targetHumanoid = hum,
		targetRoot = root,
		startedAt = now,
		lastTick = now,
		oldWalkSpeed = hum.WalkSpeed,
	}

	hum.WalkSpeed = math.min(hum.WalkSpeed, BLOOD_DRAIN_SLOW_WALKSPEED)
	makeSparkleBurst(root.Position, Color3.fromRGB(190, 0, 35), 24, 0.75)
end

function updateBloodDrain(plr)
	local session = bloodSessions[plr]
	if not session then
		return
	end

	local char = getCharacter(plr)
	local casterHum = getHumanoid(char)
	local casterRoot = getRoot(char)
	local targetHum = session.targetHumanoid
	local targetRoot = session.targetRoot

	if not hasPower(plr, "BloodManipulation")
		or not casterHum
		or casterHum.Health <= 0
		or not casterRoot
		or not targetHum
		or targetHum.Health <= 0
		or not targetRoot
		or not targetRoot.Parent then
		stopBloodDrain(plr, true)
		return
	end

	if os.clock() - session.startedAt >= BLOOD_MAX_DURATION then
		stopBloodDrain(plr, true)
		return
	end

	if (casterRoot.Position - targetRoot.Position).Magnitude > BLOOD_RANGE then
		stopBloodDrain(plr, true)
		return
	end

	local now = os.clock()
	if now - session.lastTick < BLOOD_TICK_INTERVAL then
		return
	end

	local dt = now - session.lastTick
	session.lastTick = now

	local damage = math.max(1, (targetHum.MaxHealth * BLOOD_DRAIN_MAX_HEALTH_PER_SECOND + BLOOD_DRAIN_FLAT_DAMAGE_PER_SECOND) * dt)
	local before = targetHum.Health
	targetHum:TakeDamage(damage * getDamageMultiplier(plr))
	local dealt = math.max(before - targetHum.Health, 0)
	casterHum.Health = math.min(casterHum.MaxHealth, casterHum.Health + dealt * 0.5)

	if math.random() < BLOOD_DRAIN_HEAD_POP_CHANCE then
		if tryPopHead(plr, targetHum, targetRoot, true) then
			stopBloodDrain(plr, true)
		end
	end
end

