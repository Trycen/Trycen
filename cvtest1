function isOwner(plr)
	return plr and (plr.Name == OWNER_NAME or plr.UserId == OWNER_USER_ID)
end

function getCharacter(plr)
	if not plr then
		return nil
	end

	local char = plr.Character
	if char and char.Parent then
		return char
	end

	return nil
end

function getHumanoid(model)
	if not model or not model.Parent then
		return nil
	end

	return model:FindFirstChildOfClass("Humanoid")
end

function getRoot(model)
	if not model or not model.Parent then
		return nil
	end

	return model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
end

function sendNotice(plr, text)
	if plr and plr.Parent then
		remote:FireClient(plr, "Notice", text)
	end
end

function isRandomPowerWord(value)
	if type(value) ~= "string" then
		return false
	end

	local lower = string.lower(value)
	return lower == "random" or lower == "rng" or lower == "any"
end

function isAllPowerWord(value)
	if type(value) ~= "string" then
		return false
	end

	return string.lower(value) == "all"
end

function resolvePowerName(value)
	if type(value) ~= "string" then
		return nil
	end

	local lower = string.lower(value)
	if lower == "laser" or lower == "lasereyes" or lower == "eyes" then
		return "LaserEyes"
	elseif lower == "speed" or lower == "superspeed" or lower == "fast" then
		return "SuperSpeed"
	elseif lower == "translucent" or lower == "invis" or lower == "invisible" or lower == "invisibility" then
		return "Translucent"
	elseif lower == "teleport" or lower == "teleportation" or lower == "tp" then
		return "Teleportation"
	elseif lower == "heal" or lower == "healing" or lower == "medic" then
		return "Healing"
	elseif lower == "electricity" or lower == "elec" or lower == "lightning" then
		return "Electricity"
	elseif lower == "gravity" or lower == "grav" then
		return "Gravity"
	elseif lower == "blood" or lower == "bloodmanipulation" or lower == "drain" then
		return "BloodManipulation"
	elseif lower == "vessel" then
		return "Vessel"
	end

	return nil
end

function listHasPower(list, powerName)
	if not list then
		return false
	end

	for _, power in ipairs(list) do
		if power == powerName then
			return true
		end
	end

	return false
end

function getCompoundList(plr)
	if not plr then
		return nil
	end

	return compoundPowersByUserId[plr.UserId]
end

function getTempList(plr)
	return tempPowersByPlayer[plr]
end

function getPowerSet(plr)
	local set = {}
	local compoundList = getCompoundList(plr)
	local tempList = getTempList(plr)

	if compoundList then
		for _, power in ipairs(compoundList) do
			if POWERS[power] then
				set[power] = true
			end
		end
	end

	if tempList then
		for _, power in ipairs(tempList) do
			if POWERS[power] then
				set[power] = true
			end
		end
	end

	return set
end

function hasPower(plr, powerName)
	local set = getPowerSet(plr)
	return set[powerName] == true
end

function hasAnyPower(plr)
	local set = getPowerSet(plr)
	for _ in pairs(set) do
		return true
	end

	return false
end

function hasV1(plr)
	if not plr then
		return false
	end

	return v1ByUserId[plr.UserId] == true
end

function getDamageMultiplier(plr)
	if hasV1(plr) then
