function ensureLaserState(plr)
	local char = getCharacter(plr)
	if not char then
		return nil
	end

	local head = char:FindFirstChild("Head")
	if not head then
		return nil
	end

	local existing = laserStates[plr]
	if existing and existing.folder and existing.folder.Parent and existing.head == head then
		return existing
	end

	cleanupLaserState(plr)

	local leftEye = getEyeAttachment(head, "VLaserLeftEye", Vector3.new(-0.22, 0.12, -0.55))
	local rightEye = getEyeAttachment(head, "VLaserRightEye", Vector3.new(0.22, 0.12, -0.55))
	local laserColor = laserColorByUserId[plr.UserId]
	if not laserColor then
		laserColor = randomLaserColor()
		laserColorByUserId[plr.UserId] = laserColor
	end
	local darkColor = laserColor:Lerp(Color3.new(0, 0, 0), 0.5)

	local folder = Instance.new("Folder")
	folder.Name = "CompoundVLaser_" .. plr.UserId
	folder.Parent = Workspace

	local targetPart = Instance.new("Part")
	targetPart.Name = "CompoundVLaserTarget"
	targetPart.Anchored = true
	targetPart.CanCollide = false
	targetPart.CanTouch = false
	targetPart.CanQuery = false
	targetPart.CastShadow = false
	targetPart.Transparency = 1
	targetPart.Size = Vector3.new(0.2, 0.2, 0.2)
	targetPart.CFrame = head.CFrame + head.CFrame.LookVector * 8
	targetPart.Parent = folder

	local targetAttachment = Instance.new("Attachment")
	targetAttachment.Parent = targetPart

	local leftBeam = makeBeam(leftEye, targetAttachment, laserColor, darkColor, folder, 0.22, 0.11)
	local rightBeam = makeBeam(rightEye, targetAttachment, laserColor, darkColor, folder, 0.22, 0.11)
	local leftCore = makeBeam(leftEye, targetAttachment, Color3.fromRGB(255, 255, 255), laserColor:Lerp(Color3.new(1, 1, 1), 0.45), folder, 0.08, 0.04)
	local rightCore = makeBeam(rightEye, targetAttachment, Color3.fromRGB(255, 255, 255), laserColor:Lerp(Color3.new(1, 1, 1), 0.45), folder, 0.08, 0.04)

	local light = Instance.new("PointLight")
	light.Name = "CompoundVLaserLight"
	light.Color = laserColor
	light.Brightness = 4
	light.Range = 14
	light.Enabled = false
	light.Parent = targetPart

	local state = {
		folder = folder,
		head = head,
		targetPart = targetPart,
		leftBeam = leftBeam,
		rightBeam = rightBeam,
		leftCore = leftCore,
		rightCore = rightCore,
		light = light,
		activeUntil = 0,
		startedAt = os.clock(),
	}

	laserStates[plr] = state
	return state
end

